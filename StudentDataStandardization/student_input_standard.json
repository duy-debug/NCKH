{
  "dataset_name": "student_input_standard_v1",
  "ontology_alignment": {
    "student_id": "StudentID",
    "enrollment_year": "enrollmentYear",
    "current_semester": "currentSemester",
    "chosen_specialization": "hasChosenSpecialization",
    "completed_courses": "hasCompletedCourse",
    "failed_courses": "hasFailedCourse"
  },
  "controlled_values": {
    "specialization_codes": [
      {
        "code": "CNPM",
        "label": "Công nghệ phần mềm"
      },
      {
        "code": "HTTT",
        "label": "Hệ thống thông tin"
      },
      {
        "code": "TTMMT",
        "label": "Truyền thông và mạng máy tính"
      }
    ],
    "learning_goals": [
      "Đúng hạn",
      "Học vượt",
      "Giảm tải"
    ],
    "course_status": [
      "Đạt",
      "Chưa đạt"
    ],
    "semester_range": {
      "min": 1,
      "max": 8
    },
    "grade_scale": "0-10"
  },
  "required_fields": [
    "mssv",
    "ten_sinh_vien",
    "nam_vao_hoc",
    "chuyen_nganh_chon",
    "danh_sach_mon_da_hoc",
    "diem_tung_mon",
    "trang_thai_dat_chua_dat",
    "so_tin_chi_da_tich_luy",
    "hoc_ky_hien_tai",
    "muc_tieu_hoc_tap"
  ],
  "field_spec": {
    "mssv": {
      "type": "string",
      "description": "Mã sinh viên duy nhất, ánh xạ với StudentID."
    },
    "nam_vao_hoc": {
      "type": "integer",
      "description": "Năm bắt đầu học, ánh xạ với enrollmentYear."
    },
    "chuyen_nganh_chon": {
      "type": "object",
      "description": "Chuyên ngành sinh viên đã chọn.",
      "properties": {
        "ma": "string",
        "ten": "string"
      }
    },
    "danh_sach_mon_da_hoc": {
      "type": "array[string]",
      "description": "Danh sách mã môn đã từng học, gồm cả môn đạt và chưa đạt."
    },
    "diem_tung_mon": {
      "type": "object",
      "description": "Map mã môn -> điểm hệ 10."
    },
    "trang_thai_dat_chua_dat": {
      "type": "object",
      "description": "Map mã môn -> Đạt/Chưa đạt."
    },
    "so_tin_chi_da_tich_luy": {
      "type": "integer",
      "description": "Tổng số tín chỉ chỉ tính cho các môn đạt."
    },
    "hoc_ky_hien_tai": {
      "type": "integer",
      "description": "Học kỳ hiện tại theo ontology Semester1..Semester8."
    },
    "muc_tieu_hoc_tap": {
      "type": "string",
      "description": "Mục tiêu học tập hiện tại: Đúng hạn, Học vượt, Giảm tải."
    },
    "ten_sinh_vien": {
      "type": "string",
      "description": "Họ và tên sinh viên."
    }
  },
  "validation_rules": [
    "Tat ca ma mon trong diem_tung_mon phai ton tai trong danh_sach_mon_da_hoc.",
    "Tat ca ma mon trong trang_thai_dat_chua_dat phai ton tai trong danh_sach_mon_da_hoc.",
    "Neu trang_thai_dat_chua_dat[ma_mon] = 'Đạt' thi ma_mon co the anh xa sang hasCompletedCourse.",
    "Neu trang_thai_dat_chua_dat[ma_mon] = 'Chưa đạt' thi ma_mon co the anh xa sang hasFailedCourse.",
    "so_tin_chi_da_tich_luy nen bang tong so tin chi cua cac mon co trang thai 'Đạt'.",
    "hoc_ky_hien_tai nen la so nguyen tu 1 den 8."
  ],
